knitr::opts_chunk$set(echo = TRUE)
require(poolSeq)
require(data.table)
require(dplyr)
require(tidyr)
require(IHW)
require(ACER)
require(fdrtool)
library(gridExtra)
library(grid)
require(mclust)
library(tibble)
input_gen=c(0,60)
input_rep=5
chromosomes=c("2L","2R","3L","3R","4","X")
cmh<-fread('CMH.result.gz')
cmh<-subset(cmh, adj_p<0.05)
#extract starting allele frequency
freqf<-data.frame()
for (chr in c("2L", "2R", "3L", "3R","4")){
sync<-read.sync(file=paste0("02noNA.no_0var.F0_F60.",chr,".filtered.cons.q20.no_0cov.sync.gz"),
gen = rep(input_gen, each = input_rep), repl = rep(1:input_rep, 2), polarization ="rising")
freqf=rbind(freqf,af(sync, gen = 0, repl = 1:input_rep))
#cov=as.matrix(coverage(sync, gen = rep(input_gen,each=input_rep), repl = rep(1:input_rep,2)))
#p.values<-adapted.cmh.test(freq = freqf, coverage = cov, Ne = med_Ne_auto, gen = input_gen, repl = 1:input_rep, poolSize = rep(600,ncol(freqf)))
#p_list<-c(p_list, p.values)
#locus<-rbind(locus, splitLocusID(rownames(freqf)))
}
cmh$loci<-paste(cmh$chr,cmh$pos,sep=".")
View(freqf)
freqf<-freqf[rownames(freqf) %in% cmh$loci,]
#extract starting allele frequency
freqf<-data.frame()
for (chr in c("2L", "2R", "3L", "3R","4","X")){
sync<-read.sync(file=paste0("02noNA.no_0var.F0_F60.",chr,".filtered.cons.q20.no_0cov.sync.gz"),
gen = rep(input_gen, each = input_rep), repl = rep(1:input_rep, 2), polarization ="rising")
freqf=rbind(freqf,as.data.frame(af(sync, gen = 0, repl = 1:input_rep)))
}
freqf<-freqf[rownames(freqf) %in% cmh$loci,]
freqf$median_af<-apply(freqf, 1, median)
View(freqf)
p_af<-ggdensity(freqf, "median_af", y="density", palette="4fc0c6", alpha = 0.5)+
#palette =c("#4fc0c6","#ea811c"), alpha = 0.5)+
#geom_vline(xintercept = 0, linetype="dashed", color="red")+
theme(legend.position = 'none')+
xlab("Median Allele frequency")+ylab("Density")+ggtitle("Fluctuating population")+
xlim(c(-1,1))+ylim(c(0,25))
library(ggpubr)
p_af<-ggdensity(freqf, "median_af", y="density", palette="4fc0c6", alpha = 0.5)+
#palette =c("#4fc0c6","#ea811c"), alpha = 0.5)+
