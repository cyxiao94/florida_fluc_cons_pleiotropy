anc<-rnorm(1000, mean=40,sd=10)
scaled_anc<-(anc-min(anc))/(max(anc)-min(anc))
anc<-rnorm(1000, mean=40,sd=10)
scaled_anc<-(anc-min(anc))/(max(anc)-min(anc))
evo<-rnorm(1000, mean=45,sd=15)
scaled_evo<-(evo-min(evo))/(max(evo)-min(evo))
dt<-data.table(anc=scaled_anc,
evo=scaled_evo)
dt<-data.table(anc=anc,
scaled_anc  = scaled_anc,
evo=evo,
scaled_evo=scaled_evo)
ggplot()+
geom_density(data = dt$scaled_anc)
ggplot()+
geom_density(data = dt, aes(x=dt$scaled_anc))
