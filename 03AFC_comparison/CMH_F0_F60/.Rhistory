rep1 = sub("^[A-Za-z]+", "", sample2)
)]
dt_cor[, `:=`(
treat1 = sub("[0-9]+$", "", sample1),
treat2 = sub("[0-9]+$", "", sample2),
rep1 = sub("^[A-Za-z]+", "", sample1),
rep2 = sub("^[A-Za-z]+", "", sample2)
)]
dt_cor[, category := fifelse(treat1 != treat2 & rep1 == rep2, "same replicate",
fifelse(treat1 == treat2, "within_treatment", "between_treatment")
)]
ggplot(dt_cor, aes(x=category, y = correlation))+
geom_boxplot()
p<- ggplot(dt_cor, aes(x=category, y=correlation, fill = category))+
geom_boxplot()+
geom_signif(comparisons = list(c("between_treatment","within_treatment")),
#y_position = c(0.4,0.5,0.45),
map_signif_level = TRUE,
test = "wilcox.test",
test.args = list(alternative = "less"))+
labs(title = "Allele Frequency change correlation", x = "Comparison")+
theme(legend.position = "none",
panel.background = element_rect(fill = "white", colour = "black"),
axis.text = element_text(size = 12),
axis.title = element_text(size=15),title = element_text(size=18))
plot(p)
